  "levels_off_label": {
    "message": "Off"
  },
  "levels_off_description": {
    "message": "Disables all optimization, metrics, diagnostics, events, and debug recording. Only the control panel itself remains operable."
  },
  "levels_off_risk": {
    "message": "Does not affect any native functionality."
  },
  "levels_monitor_label": {
    "message": "Monitor"
  },
  "levels_monitor_description": {
    "message": "Disables page optimization while keeping page recognition, message stats, diagnostics, events, and debug recording available."
  },
  "levels_monitor_risk": {
    "message": "Does not affect any native functionality."
  },
  "levels_standard_label": {
    "message": "Standard"
  },
  "levels_standard_description": {
    "message": "The standard takeover strategy incrementally optimizes medium-sized offscreen content to reduce rendering and scrolling load in long conversations."
  },
  "levels_standard_risk": {
    "message": "A relatively conservative optimization strategy that has almost no impact on native features."
  },
  "levels_performance_label": {
    "message": "Performance"
  },
  "levels_performance_description": {
    "message": "A more effective optimization strategy that folds and compresses distant content in place, then restores it in batches as it approaches the viewport."
  },
  "levels_performance_risk": {
    "message": "Viewing folded messages triggers a brief restore process and may affect native features."
  },
  "levels_extreme_label": {
    "message": "Extreme"
  },
  "levels_extreme_description": {
    "message": "A more aggressive optimization strategy than Performance, with stronger optimization results. Coming in the next version. Stay tuned."
  },
  "levels_extreme_risk": {
    "message": "Not selectable yet."
  },
